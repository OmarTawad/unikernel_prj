# UniSplit Environment Variables
# Copy to .env and modify as needed

# Cloud service
UNISPLIT_CLOUD_HOST=0.0.0.0
UNISPLIT_CLOUD_PORT=8000
UNISPLIT_BACKEND_TYPE=pytorch_cpu

# Edge simulator
UNISPLIT_CLOUD_URL=http://localhost:8000
UNISPLIT_MEMORY_BUDGET=25165824
UNISPLIT_OVERHEAD_BYTES=2097152
UNISPLIT_DEFAULT_POLICY=static_kmin

# Paths
UNISPLIT_DATA_RAW_DIR=data/raw
UNISPLIT_DATA_PROCESSED_DIR=data/processed
UNISPLIT_DATA_METADATA_DIR=data/metadata
UNISPLIT_DATA_SPLITS_DIR=data/splits
UNISPLIT_CHECKPOINT_DIR=checkpoints
UNISPLIT_PARTITION_DIR=partitions
UNISPLIT_PROFILE_DIR=profiles

# Training
UNISPLIT_BATCH_SIZE=256
UNISPLIT_EPOCHS=50
UNISPLIT_LEARNING_RATE=0.001
UNISPLIT_SEED=42
UNISPLIT_DEVICE=cpu

# Logging
UNISPLIT_LOG_LEVEL=INFO
UNISPLIT_LOG_FORMAT=json
