# Pi edge-runtime runtime parameters (pre-hardware template).
# These values are rendered into Pi boot `cmdline.txt` for the unikernel app.

# Edge split to run by default in first network bring-up.
UNISPLIT_EDGE_SPLIT_ID=7

# Transport backend selection:
# - posix: host-side userspace testing only
# - ukstub: deterministic stub path
# - lwip: real socket-backed backend for Unikraft/Pi bring-up
UNISPLIT_TRANSPORT_BACKEND=lwip

# Cloud endpoint (VPS) for day-1 Pi bring-up.
# NOTE: current lwIP backend path expects IPv4 literal endpoint format:
#       http://<ipv4>:<port>
UNISPLIT_TRANSPORT_ENDPOINT="http://204.168.156.245:8000"
UNISPLIT_CLOUD_URL="http://204.168.156.245:8000"
UNISPLIT_TRANSPORT_PATH=/infer/split
UNISPLIT_TRANSPORT_TIMEOUT_SECONDS=10
UNISPLIT_TRANSPORT_RETRIES=3

# Edge artifact source and model version.
UNISPLIT_ARTIFACTS_ROOT=edge_native/artifacts/c_splits
UNISPLIT_MODEL_VERSION=v0.1.0
