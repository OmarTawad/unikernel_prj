+static inline __u16 rpi4_irqg_uart_read(__u64 offset)
+{
+	return *((volatile __u16 *)(RPI4_IRQG_UART_BASE + offset));
+}
+
+static inline void rpi4_irqg_uart_write(__u64 offset, __u16 value)
+{
+	*((volatile __u16 *)(RPI4_IRQG_UART_BASE + offset)) = value;
+}
+
+static void rpi4_irqg_uart_putc(char ch)
+{
+	while (rpi4_irqg_uart_read(RPI4_IRQG_UARTFR_OFFSET) & RPI4_IRQG_FR_TXFF)
+		;
+
+	rpi4_irqg_uart_write(RPI4_IRQG_UARTDR_OFFSET, (__u16)(ch & 0xff));
+}
+
+static void rpi4_irqg_uart_puts(const char *s)
+{
+	while (*s) {
+		if (*s == '\n')
+			rpi4_irqg_uart_putc('\r');
+		rpi4_irqg_uart_putc(*s++);
+	}
+}
+
+static void rpi4_irqg_uart_put_hex_nibble(__u8 nibble)
+{
+	static const char hex[] = "0123456789abcdef";
+
+	rpi4_irqg_uart_putc(hex[nibble & 0xf]);
+}
+
+static void rpi4_irqg_uart_put_hex32(__u32 value)
+{
+	int shift;
+
+	for (shift = 28; shift >= 0; shift -= 4)
+		rpi4_irqg_uart_put_hex_nibble((__u8)(value >> shift));
+}
+
+static void rpi4_irqg_uart_put_hex64(__u64 value)
+{
+	int shift;
+
+	for (shift = 60; shift >= 0; shift -= 4)
+		rpi4_irqg_uart_put_hex_nibble((__u8)(value >> shift));
+}
