+static inline __u16 rpi4_ei_uart_read(__u64 offset)
+{
+	return *((volatile __u16 *)(RPI4_EI_UART_BASE + offset));
+}
+
+static inline void rpi4_ei_uart_write(__u64 offset, __u16 value)
+{
+	*((volatile __u16 *)(RPI4_EI_UART_BASE + offset)) = value;
