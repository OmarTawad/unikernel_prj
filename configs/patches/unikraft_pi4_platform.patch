+#if CONFIG_KVM_VMM_RPI4
+/* Bypass console registration so we can prove control reached _ukplat_entry()
+ * even when the DTB lacks a usable stdout-path for early console setup.
+ */
+#define RPI4_EMERGENCY_PL011_BASE 0xFE201000UL
+#define RPI4_EMERGENCY_UARTDR_OFFSET 0x00UL
+#define RPI4_EMERGENCY_UARTFR_OFFSET 0x18UL
+#define RPI4_EMERGENCY_FR_TXFF (1U << 5)
+#define RPI4_P1_EARLY_MARKER "UNISPLIT_RPI4_P1_EARLY_ENTRY\n"
+
+static inline __u16 rpi4_emergency_uart_read(__u64 offset)
+{
+	return *((volatile __u16 *)(RPI4_EMERGENCY_PL011_BASE + offset));
+}
+
+static inline void rpi4_emergency_uart_write(__u64 offset, __u16 value)
+{
+	*((volatile __u16 *)(RPI4_EMERGENCY_PL011_BASE + offset)) = value;
+}
+
+static void rpi4_emergency_uart_putc(char ch)
+{
+	while (rpi4_emergency_uart_read(RPI4_EMERGENCY_UARTFR_OFFSET) &
+	       RPI4_EMERGENCY_FR_TXFF)
+		;
+
+	rpi4_emergency_uart_write(RPI4_EMERGENCY_UARTDR_OFFSET,
+				  (__u16)(ch & 0xff));
+}
+
+static void rpi4_emergency_uart_puts(const char *s)
+{
+	while (*s) {
+		if (*s == '\n')
+			rpi4_emergency_uart_putc('\r');
+		rpi4_emergency_uart_putc(*s++);
+	}
+}
+#endif /* CONFIG_KVM_VMM_RPI4 */
+
