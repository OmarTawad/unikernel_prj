+
+static inline __u16 rpi4_bootinfo_uart_read(__u64 offset)
+{
+	return *((volatile __u16 *)(RPI4_BOOTINFO_PL011_BASE + offset));
+}
+
+static inline void rpi4_bootinfo_uart_write(__u64 offset, __u16 value)
+{
+	*((volatile __u16 *)(RPI4_BOOTINFO_PL011_BASE + offset)) = value;
+}
+
+static void rpi4_bootinfo_uart_putc(char ch)
+{
+	while (rpi4_bootinfo_uart_read(RPI4_BOOTINFO_UARTFR_OFFSET) &
+	       RPI4_BOOTINFO_FR_TXFF)
+		;
+
+	rpi4_bootinfo_uart_write(RPI4_BOOTINFO_UARTDR_OFFSET,
+				 (__u16)(ch & 0xff));
+}
+
+static void rpi4_bootinfo_uart_puts(const char *s)
+{
+	while (*s) {
+		if (*s == '\n')
+			rpi4_bootinfo_uart_putc('\r');
+		rpi4_bootinfo_uart_putc(*s++);
+	}
+}
+
+static void rpi4_bootinfo_uart_put_hex_nibble(__u8 nibble)
+{
+	static const char hex[] = "0123456789abcdef";
+
+	rpi4_bootinfo_uart_putc(hex[nibble & 0xf]);
+}
+
+static void rpi4_bootinfo_uart_put_hex32(__u32 value)
+{
+	int shift;
+
+	for (shift = 28; shift >= 0; shift -= 4)
+		rpi4_bootinfo_uart_put_hex_nibble((__u8)(value >> shift));
+}
+
+static void rpi4_bootinfo_uart_put_hex64(__u64 value)
+{
+	int shift;
+
+	for (shift = 60; shift >= 0; shift -= 4)
+		rpi4_bootinfo_uart_put_hex_nibble((__u8)(value >> shift));
+}
+
+static __u32 rpi4_bootinfo_read_be32(const volatile __u8 *ptr)
+{
+	return ((__u32)ptr[0] << 24) |
+	       ((__u32)ptr[1] << 16) |
+	       ((__u32)ptr[2] << 8) |
+	       (__u32)ptr[3];
+}
+
+static void __noreturn rpi4_bootinfo_crash(const char *s)
+{
+	rpi4_bootinfo_uart_puts(RPI4_P1_BOOTINFO_CRASH_PREFIX);
+	rpi4_bootinfo_uart_puts(s);
+	rpi4_bootinfo_uart_puts("\n");
+	ukplat_crash();
+}
+
+#define ukplat_bootinfo_crash(s)		rpi4_bootinfo_crash(s)
+#else
